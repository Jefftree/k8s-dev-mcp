{
  "name": "k8s-dev-mcp",
  "version": "0.1.0",
  "description": "MCP server for Kubernetes KEPs, contributor guidelines, and official documentation",
  "type": "module",
  "bin": {
    "k8s-dev-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "config.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "kubernetes",
    "k8s",
    "kep"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
